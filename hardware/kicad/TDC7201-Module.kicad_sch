  ;; -------------------------------------------------------------------------
  ;; Schematic-level wires (abbreviated – key connections shown)
  ;;
  ;; J1 (SMA PPS) → R_TERM1 → C_AC1 → U4.IN+ → (TL07401 delay) → U3.START
  ;; J2 (SMA 10MHz) → R_TERM2 → C_AC2 → U5.IN+ → U3.STOP1
  ;; U3.SDO/SDA → U7.GPIO5 (MISO)
  ;; U3.SCLK/SCL → U7.GPIO4 (SCK)
  ;; U3.SDI → U7.GPIO6 (MOSI)
  ;; U3.~{CSB} → U7.GPIO7 (CS)
  ;; U3.~{INT} → U7.GPIO10
  ;; U3.ENABLE → U7.GPIO8
  ;; U3.TRIG → U7.GPIO9
  ;; U2.IN ← +5V (USB-C through ESD diode)
  ;; U2.OUT → +3V3 (TDC7201, ESP32-C3)
  ;; -------------------------------------------------------------------------

  ;; -------------------------------------------------------------------------
  ;; Decoupling capacitors (representative – all 100 nF 0603 X5R)
  ;; -------------------------------------------------------------------------
  ;; C1–C10: 100 nF decoupling near each IC power pin
  ;; C11–C12: 10 µF bulk at USB input and LDO output
  ;; L1–L2: BLM21PG221SN1D ferrite beads (analog/digital power separation)

  ;; -------------------------------------------------------------------------
  ;; Test points (TP1–TP12)
  ;; TP1: +5V rail       TP2: GND            TP3: +3V3 rail
  ;; TP4: START signal   TP5: STOP signal     TP6: TDC7201 CLK
  ;; TP7: SPI_SCK        TP8: SPI_MOSI        TP9: SPI_MISO
  ;; TP10: TDC_INT       TP11: PPS_IN (raw)   TP12: 10MHz_IN (raw)
  ;; -------------------------------------------------------------------------

  ;; -------------------------------------------------------------------------
  ;; SMA Connectors
  ;; J1: PPS Input (SMA)
  ;; J2: 10 MHz Reference Input (SMA)
  ;; J3: WiFi Antenna (SMA / IPX)
  ;; -------------------------------------------------------------------------

